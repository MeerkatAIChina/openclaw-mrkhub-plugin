{
  "id": "mrkhub",
  "name": "Meerkat Skills Hub",
  "description": "Search and install Meerkat skills from GitHub via /mrkhub",
  "contracts": {
    "tools": ["mrkhub_search", "mrkhub_install"]
  },
  "toolMetadata": {
    "mrkhub_search": { "optional": true },
    "mrkhub_install": { "optional": true }
  },
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "ossBaseUrl": {
        "type": "string",
        "description": "OSS bucket base URL for skills (default: https://meerkatai-skills.oss-cn-shanghai.aliyuncs.com)"
      },
      "installDir": {
        "type": "string",
        "description": "Target directory for installed skills (default ~/.agents/skills)"
      }
    }
  }
}
